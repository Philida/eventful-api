generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdEvents Event[]        @relation("CreatorEvents")
  favorites     Favorite[]
  notifications Notification[]
  reminders     Reminder[]
  reviews       Review[]
  tickets       Ticket[]
}

model Event {
  id            String         @id @default(uuid())
  title         String
  description   String
  location      String
  eventDate     DateTime
  ticketPrice   Float
  totalTickets  Int
  creatorId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  imageUrl      String?
  category      EventCategory  @default(TECHNOLOGY)
  creator       User           @relation("CreatorEvents", fields: [creatorId], references: [id])
  favorites     Favorite[]
  notifications Notification[]
  reminders     Reminder[]
  reviews       Review[]
  tickets       Ticket[]
}

model Ticket {
  id        String   @id @default(uuid())
  qrCode    String?
  isScanned Boolean  @default(false)
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  payment   Payment?
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  amount    Float
  reference String        @unique
  status    PaymentStatus
  ticketId  String        @unique
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  ticket    Ticket        @relation(fields: [ticketId], references: [id])
}

model Reminder {
  id        String   @id @default(uuid())
  remindAt  DateTime
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  CREATOR
  EVENTEE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum EventCategory {
  TECHNOLOGY
  BUSINESS
  MUSIC
  SPORTS
  EDUCATION
}
